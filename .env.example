# Copie para ".env" e preencha com valores reais.
# Usado apenas em PRODUÇÃO (docker-compose.prod.yml).
# NUNCA cometa o arquivo ".env" no Git.

# ====== Banco de dados ======
POSTGRES_USER=admin
POSTGRES_PASSWORD=gere_uma_senha_forte_aqui
POSTGRES_DB=confeitaria

# ====== Domínios (produção) ======
N8N_HOST=n8n.seudominio.com
N8N_WEBHOOK_URL=https://n8n.seudominio.com
APP_URL=https://app.seudominio.com
# API_URL: endereço INTERNO do backend no Docker — não usar URL pública aqui.
# O nginx do frontend faz proxy internamente; usar a URL pública criaria
# round-trip pelo Cloudflare e quebraria se o túnel estiver offline.
API_URL=http://backend:3000
EVOLUTION_URL=https://evolution.seudominio.com
CORS_ORIGIN=https://app.seudominio.com


# ====== Backend ======
# Gere com: openssl rand -hex 32
BACKEND_API_KEY=
# Gere com: openssl rand -hex 32
JWT_SECRET=
# Senhas dos usuários criados pelo prisma db seed (obrigatório — sem valor padrão)
SEED_PASSWORD_CONFEITEIRA=
SEED_PASSWORD_FUNCIONARIA=

# ====== Evolution API ======
# Gere com: openssl rand -hex 32
EVOLUTION_API_KEY=

# ====== Cloudflare Tunnel ======
TUNNEL_TOKEN=
