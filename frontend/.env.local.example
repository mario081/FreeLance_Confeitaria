# Copie para "frontend/.env.local" para desenvolvimento local.
# NUNCA cometa "frontend/.env.local" no Git.
#
# DEV_API_* NÃO têm prefixo VITE_ intencionalmente:
# o Vite só expõe ao browser vars com prefixo VITE_.
# Estas vars são usadas apenas pelo proxy do servidor de dev (Node.js),
# nunca chegam ao bundle JavaScript.

DEV_API_TARGET=http://localhost:3000
DEV_API_KEY=valor_da_BACKEND_API_KEY_do_seu_.env
