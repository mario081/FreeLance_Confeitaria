# Copie para "backend/.env" para desenvolvimento local.
# NUNCA cometa "backend/.env" no Git.

DATABASE_URL=postgresql://admin:devpassword@localhost:5433/confeitaria?schema=public
BACKEND_API_KEY=dev-api-key-local
CORS_ORIGIN=http://localhost:5173

# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Senhas iniciais dos usuários (usadas apenas no npm run db:seed)
SEED_PASSWORD_CONFEITEIRA=
SEED_PASSWORD_FUNCIONARIA=
